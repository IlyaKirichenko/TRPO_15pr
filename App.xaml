<Application x:Class="TRPO_KI_15pr_ElectronicShop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TRPO_KI_15pr_ElectronicShop"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Teal" SecondaryColor="Cyan"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="PrimaryMidBrush" Color="#00C4B4"/>
            <SolidColorBrush x:Key="SecondaryMidBrush" Color="#00b4c4"/>
            <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="White"/>
            <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="White"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
