<Page x:Class="TRPO_KI_15pr_ElectronicShop.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TRPO_KI_15pr_ElectronicShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Вход">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Магазин электроники"
           FontSize="24"
           FontWeight="Bold"
           HorizontalAlignment="Center"
           Margin="0 0 0 20"/>

            <Button Height="30" Width="200" Background="#00C4B4" Foreground="White" Margin="0 0 0 20" Click="LoginUser_Click">Войти как пользователь</Button>

            <Button Height="30" Width="200" Background="#00C4B4" Foreground="White" Margin="0 0 0 10" Click="LoginManager_Click">Войти как менеджер</Button>
            <PasswordBox x:Name="PinCode" Height="30" Background="#00C4B4" Width="200" BorderThickness="3" BorderBrush="#00b4c4" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"></PasswordBox>
        </StackPanel>
    </Grid>
</Page>
