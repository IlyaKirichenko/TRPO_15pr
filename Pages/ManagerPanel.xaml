<Page x:Class="TRPO_KI_15pr_ElectronicShop.Pages.ManagerPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TRPO_KI_15pr_ElectronicShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Панель управления">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Панель управления" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <Button Content="Управление товарами" 
                    Background="#00C4B4" 
                    Width="200" 
                    Height="40" 
                    Margin="5"
                    Click="ManageProducts_Click"/>

            <Button Content="Управление категориями" 
                    Background="#00C4B4" 
                    Width="200" 
                    Height="40" 
                    Margin="5"
                    Click="ManageCategories_Click"/>

            <Button Content="Управление брендами" 
                    Background="#00C4B4" 
                    Width="200" 
                    Height="40" 
                    Margin="5"
                    Click="ManageBrands_Click"/>

            <Button Content="Управление тегами" 
                    Background="#00C4B4" 
                    Width="200" 
                    Height="40" 
                    Margin="5"
                    Click="ManageTags_Click"/>

            <Button Content="Назад" 
                    Background="#CCCCCC" 
                    Width="200" 
                    Height="40" 
                    Margin="5,20,5,5"
                    Click="Back_Click"/>
        </StackPanel>
    </Grid>
</Page>
