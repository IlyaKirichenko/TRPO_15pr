<Page x:Class="TRPO_KI_15pr_ElectronicShop.Pages.ManageProducts"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TRPO_KI_15pr_ElectronicShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      Title="Управление товарами" Loaded="Page_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Управление товарами"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>
        <StackPanel Grid.Row="1" 

                    Margin="0,0,0,10">
            <TextBlock Text="Добавить/Редактировать товар" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="5"/>
                
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Описание:" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtDescription" Grid.Row="1" Grid.Column="1" Margin="5" Height="60" TextWrapping="Wrap"/>
                
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Цена:" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPrice" Grid.Row="2" Grid.Column="1" Margin="5"/>
                
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Остаток:" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtStock" Grid.Row="3" Grid.Column="1" Margin="5" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Рейтинг:" Margin="5" VerticalAlignment="Center"/>
                <TextBox x:Name="txtRating" Grid.Row="4" Grid.Column="1" Margin="5" PreviewTextInput="txtRating_PreviewTextInput"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Категория:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbCategory" Grid.Row="5" Grid.Column="1" Margin="5" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Бренд:" Margin="5" VerticalAlignment="Center"/>
                <ComboBox x:Name="cmbBrand" Grid.Row="6" Grid.Column="1" Margin="5" />

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Теги:" Margin="5" VerticalAlignment="Center"/>
                <ListBox x:Name="lbTags" Grid.Row="7" Grid.Column="1" Margin="5" Height="90" SelectionMode="Multiple"/>

            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button Content="Добавить" Background="#00C4B4" Width="100" Height="35" Margin="5" Click="Add_Click"/>
                <Button Content="Обновить" Background="#00C4B4" Width="100" Height="35" Margin="5" Click="Update_Click"/>
            </StackPanel>
        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Список товаров" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListView x:Name="lvProducts" Grid.Row="1" 
          SelectionChanged="lvProducts_SelectionChanged"
          Background="White" 
          BorderBrush="#00b4c4" 
          BorderThickness="1">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" Margin="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Id}"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Price}"/>
                                <TextBlock Grid.Column="3" Text="{Binding Stock}"/>
                                <TextBlock Grid.Column="4" Text="{Binding Rating}"/>
                                <TextBlock Grid.Column="5" Text="{Binding Category.Name}"/>
                                <TextBlock Grid.Column="6" Text="{Binding Brand.Name}"/>

                                <StackPanel Grid.Column="6" Orientation="Horizontal">
                                    <ItemsControl ItemsSource="{Binding Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="2">
                                                    <TextBlock Text="{Binding Name, StringFormat='#{0} '}" 
                                                   Foreground="#555555" 
                                                   FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Удалить" Background="#00b4c4" Foreground="White" Width="100" Height="35" Margin="5" Click="Delete_Click"/>
                <Button Content="Назад" Background="#00C4B4" Width="100" Height="35" Margin="5" Click="Back_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
