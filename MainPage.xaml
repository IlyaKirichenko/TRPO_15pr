<Page x:Class="TRPO_KI_15pr_ElectronicShop.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TRPO_KI_15pr_ElectronicShop.Pages"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
      xmlns:converters="clr-namespace:TRPO_KI_15pr_ElectronicShop.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="800"
      DataContext="{Binding RelativeSource={RelativeSource Self}}"
      Title="Каталог" Loaded="LoadList">
    <Page.Resources>
        <converters:LessThanConverters x:Key="StockToBorderBrushConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <Label>Поиск</Label>
            <TextBox x:Name="SearchTextBox" Margin="10" Background="#00C4B4" 
         Text="{Binding searchQuery, UpdateSourceTrigger=PropertyChanged}"
         TextChanged="TextBox_TextChanged"
         materialDesign:HintAssist.Hint="Введите текст для поиска"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="0">
            <Label FontSize="16">Сортировка</Label>
            <ComboBox Margin="10"  Background="#00C4B4" SelectionChanged="ComboBox_SelectionChanged">
                <ComboBox.Items>
                    <ComboBoxItem Tag="Name">По алфавиту</ComboBoxItem>
                    <ComboBoxItem Tag="CheaperFirst">Сначала дешевле</ComboBoxItem>
                    <ComboBoxItem Tag="ExpensiveFirst">Сначала дороже</ComboBoxItem>
                    <ComboBoxItem Tag="QuantityDecrease">Количество (убывание)</ComboBoxItem>
                    <ComboBoxItem Tag="QuantityGrowth">Количество (возрастание)</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>
            <Label>Фильтры</Label>
            <StackPanel>
            <Label FontSize="16">Фильтр по брендам</Label>
                <ComboBox x:Name="BrandFilter" Margin="10" Background="#00C4B4" SelectionChanged="BrandFilter_SelectionChanged">
                    <ComboBoxItem Tag="0">Все бренды</ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <StackPanel>
                <Label FontSize="16">Фильтр по категориям</Label>
                <ComboBox x:Name="CategoryFilter" Margin="10" Background="#00C4B4" SelectionChanged="CategoryFilter_SelectionChanged">
                    <ComboBoxItem Tag="0">Все категории</ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <StackPanel>
                <Label FontSize="16">Фильтр по цене</Label>
                <Label>от</Label>
                <TextBox x:Name="PriceFromTextBox" Margin="10" Background="#00C4B4" 
         Text="{Binding filterPriceFrom, UpdateSourceTrigger=PropertyChanged}"
         TextChanged="TextBox_TextChanged"/>
                <Label>до</Label>
                <TextBox x:Name="PriceToTextBox" Margin="10" Background="#00C4B4" 
         Text="{Binding filterPriceTo, UpdateSourceTrigger=PropertyChanged}"
         TextChanged="TextBox_TextChanged"/>
            </StackPanel>
            <Button Margin="5" Background="#00C4B4" Click="ResetFilters_Click">Сбросить</Button>
            <Button Visibility="Collapsed" x:Name="ManagerButton" Margin="5" Background="#00C4B4" Click="OpenManegerPanel_Click">Панель управления</Button>
        </StackPanel>

        <materialDesign:ColorZone Grid.Row="1" Grid.Column="1" Background="#00b4c4">
            <ListView ItemsSource="{Binding products}" Name="ProductsList" HorizontalContentAlignment="Stretch" >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" 
                         BorderBrush="{Binding Stock, Converter={StaticResource StockToBorderBrushConverter}}"
                        BorderThickness="2" 
                        CornerRadius="8" 
                        Margin="5" 
                        Padding="10">
                        <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="{Binding Name}"/>
                                <TextBlock Foreground="Orange" Text="{Binding Rating, StringFormat='⭐{0} рейтинг'}"/>
                                <TextBlock>
                         <Run Text="Категория: "/>
                         <Run Text="{Binding Category.Name}"/>
                                </TextBlock>
                                <TextBlock>
                         <Run Text="{Binding Description}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1">
                                <TextBlock HorizontalAlignment="Right">
                                 <Run Text="{Binding Price}"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Right" Margin="0 20 0 0">
                                 <Run Text="Остаток: "/>
                                 <Run Text="{Binding Stock}"/>
                                </TextBlock>
                            </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,10,0,0">
                                    <ItemsControl ItemsSource="{Binding Tags}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name, StringFormat='#{0} '}" 
                                               Foreground="#555555" 
                                               FontSize="11"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </materialDesign:ColorZone>
        <WrapPanel Grid.Row="2" Grid.ColumnSpan="2">
            <TextBlock Text="{Binding products.Count, StringFormat='{}Всего записей:{0}'}"/>
            <TextBlock Text="{Binding Items.Count, ElementName=ProductsList, StringFormat='{} Показано: {0}'}"/>
        </WrapPanel>
    </Grid>
</Page>
